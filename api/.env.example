# API runtime
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# Database (Postgres connection string)
DATABASE_URL=postgres://aquastat:CHANGE_ME@db:5432/aquastat

# JWT secret (generate with: openssl rand -base64 48)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_48_CHARS
JWT_EXPIRES_IN=7d

# CORS — allowed origins (comma separated)
CORS_ORIGINS=https://aquastat.pakkou.cloud,http://localhost:5173

# Email (forgot-password) — leave blank to disable in MVP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aquastat.pakkou.cloud

# Seed admin (used by `npm run db:seed`)
SEED_FEDERATION_ADMIN_EMAIL=admin@aquastat.cy
SEED_FEDERATION_ADMIN_PASSWORD=ChangeMe!2026

# AI extraction (Anthropic API)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6
# Local file storage path (mount as volume in Coolify for persistence)
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_BYTES=26214400
